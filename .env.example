TELOXIDE_TOKEN=your_telegram_bot_token
GITHUB_PAT=your_github_personal_access_token
GITHUB_OWNER=github_username_or_org
GITHUB_REPO=repository_name

# Default Assignee (GitHub Username)
GITHUB_ASSIGNEE=your_github_username

# GitHub Project V2 Integration
# The organization login where the project resides
GITHUB_PROJECT_ORG=Ogonek-Education
# The project number (e.g. 1 for https://github.com/orgs/Ogonek-Education/projects/1)
GITHUB_PROJECT_NUMBER=1

# Comma-separated list of Telegram User IDs allowed to use the bot
ALLOWED_USER_IDS=12345678,98765432
# Specific Chat ID where the bot is allowed to operate.
TARGET_CHAT_ID=
# (Optional) Specific Topic ID (Thread ID) within the group.
TARGET_THREAD_ID=
